# Orion build-time configuration
# Use a TMDB API Read Access Token (Bearer token), not the short API key.
VITE_TMDB_READ_TOKEN=replace_with_your_tmdb_read_access_token

# Optional local-development fallback used only by Electron's main process.
# Do not rename this to VITE_* or distribute your private provider key.
ORION_WYZIE_API_KEY=replace_with_your_wyzie_api_key
ORION_SUBDL_API_KEY=replace_with_your_subdl_api_key

# Optional Google OAuth Credentials for backup/sync (Desktop App client type)
ORION_GOOGLE_CLIENT_ID=replace_with_your_google_client_id.apps.googleusercontent.com
ORION_GOOGLE_CLIENT_SECRET=replace_with_your_google_client_secret
