{
  "name": "orion",
  "version": "2.0.0",
  "description": "Orion X Music Planet — A universe made to be felt.",
  "author": "Orion",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OK-ALI/orion.git"
  },
  "bugs": {
    "url": "https://github.com/OK-ALI/orion/issues"
  },
  "homepage": "https://github.com/OK-ALI/orion#readme",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "vite build",
    "test": "npm run test:node && npm run test:renderer",
    "test:node": "node --test tests/unit/main/*.test.js tests/integration/*.test.js",
    "test:renderer": "vitest run",
    "test:electron": "playwright test --config tests/electron/playwright.config.js",
    "check:source-size": "node scripts/check-source-size.js",
    "check:bindings": "node scripts/check-renderer-bindings.js",
    "check:ipc": "node scripts/check-ipc-contract.js",
    "check:secrets": "node scripts/check-secrets.js",
    "check:theme-colors": "node scripts/check-theme-colors.js",
    "check:cycles": "madge --circular --extensions js,jsx src/renderer src/main",
    "check": "npm run check:source-size && npm run check:bindings && npm run check:ipc && npm run check:secrets && npm run check:theme-colors && npm run check:cycles && npm test && npm run build",
    "dev": "vite build --watch",
    "start": "vite build && electron .",
    "dist:win": "cross-env ELECTRON_DIST=1 vite build && electron-builder --win --publish never",
    "dist:linux": "cross-env ELECTRON_DIST=1 vite build && electron-builder --linux deb AppImage --publish never",
    "dist:mac": "cross-env ELECTRON_DIST=1 vite build && electron-builder --mac --universal --publish never"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.8",
    "@react-three/fiber": "^8.18.0",
    "chokidar": "^5.0.0",
    "gsap": "^3.15.0",
    "music-metadata": "^11.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "electron": "37.3.1",
    "electron-builder": "^26.7.0",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.orion.musicplanet",
    "productName": "Orion X Music Planet",
    "asar": true,
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "src/shared/**/*",
      "index.js",
      "preload.js",
      "popout-preload.js",
      "package.json",
      ".env",
      "!**/*.map",
      "!**/node_modules/.cache/**",
      "!**/node_modules/vite/**",
      "!**/node_modules/@vitejs/**",
      "!**/node_modules/terser/**",
      "!**/node_modules/rollup/**",
      "!**/node_modules/esbuild/**",
      "!**/node_modules/@esbuild/**",
      "!**/node_modules/@rollup/**"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "public/icon.png"
    },
    "extraResources": [
      {
        "from": "public/icon.png",
        "to": "icon.png"
      },
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
