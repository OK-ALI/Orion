{
  "name": "orion",
  "version": "1.0.4",
  "description": "Orion — A Multiverse of Stories",
  "author": "Orion",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OK-ALI/orion.git"
  },
  "bugs": {
    "url": "https://github.com/OK-ALI/orion/issues"
  },
  "homepage": "https://github.com/OK-ALI/orion#readme",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "start": "vite build && electron .",
    "dist:win": "cross-env ELECTRON_DIST=1 vite build && electron-builder --win --publish never",
    "dist:linux": "cross-env ELECTRON_DIST=1 vite build && electron-builder --linux deb AppImage --publish never",
    "dist:mac": "cross-env ELECTRON_DIST=1 vite build && electron-builder --mac --universal --publish never"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "electron": "^40.10.4",
    "electron-builder": "^26.7.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.orion.app",
    "productName": "Orion",
    "asar": true,
    "files": [
      "dist/**/*",
      "src/ipc/**/*",
      "index.js",
      "preload.js",
      "package.json",
      "!**/*.map",
      "!**/node_modules/.cache/**",
      "!**/node_modules/vite/**",
      "!**/node_modules/@vitejs/**",
      "!**/node_modules/terser/**",
      "!**/node_modules/rollup/**",
      "!**/node_modules/esbuild/**",
      "!**/node_modules/@esbuild/**",
      "!**/node_modules/@rollup/**"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "public/icon.png"
    },
    "extraResources": [
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ]
  }
}
